# Copy this file to .env and fill only the providers you want to use.

OPENAI_API_KEY=
GEMINI_API_KEY=

# Azure OpenAI GPT-Image-2 image generation.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_GPT_IMAGE_2_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=preview

# Optional: enable search grounding for supported Gemini image models.
GEMINI_ENABLE_SEARCH=0
